{
  "name": "context-bridge",
  "version": "0.0.1",
  "private": true,
  "description": "MCP server giving AI assistants structured access to a GitHub repository.",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "context-bridge": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun --hot run src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile --target=bun-linux-x64 src/server.ts --outfile dist/context-bridge",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.2"
  }
}
