# GitHub Personal Access Token.
#   Read-only mode (default):  repo:read, issues:read, pull_requests:read
#   Write mode (WRITES_ENABLED=true):  add issues:write, pull_requests:write,
#     contents:write — or for classic PATs, the `repo` (or `public_repo`) scope.
# Generate at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# Optional: pin which repo the server defaults to. Format: owner/repo.
# Tools accept an explicit repo arg too; this is just the fallback.
DEFAULT_REPO=

# Optional: cache TTL in seconds (default 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Optional: log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info

# --- Write surface (opt-in) ---
# When true, the server registers six write tools (comment_on_issue,
# comment_on_pr, label_issue, create_branch, commit_files, open_pr) AND
# asserts the token has write-capable scopes at startup. Default: false
# (read-only). The agent never closes/merges PRs, never pushes to default
# branch, never force-pushes — those are HITL-only by design.
WRITES_ENABLED=false

# --- LLM provider (vendor-agnostic port; first consumer arrives in a
# later phase). Adding a new provider = one adapter file + enum entry. ---
LLM_PROVIDER=groq
LLM_API_KEY=
# Optional: override the provider's default model.
LLM_MODEL=

# --- Companion UI (separate process, only relevant for `bun run ui:dev`) ---

# Bind host/port for the companion UI HTTP server.
COMPANION_HOST=127.0.0.1
COMPANION_PORT=8787

# Per-IP token bucket — capacity = burst, refill = sustained req/sec.
COMPANION_RATE_CAPACITY=30
COMPANION_RATE_REFILL_PER_SEC=1

# How the companion UI spawns the MCP server child. Override only if you
# distribute a compiled binary or move the entry point.
COMPANION_MCP_COMMAND=bun
COMPANION_MCP_ARGS=run src/server.ts
